{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "py \"${CLAUDE_PROJECT_DIR}/.claude/hooks/check_secrets.py\"",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "py \"${CLAUDE_PROJECT_DIR}/.claude/hooks/check_secrets.py\"",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "py \"${CLAUDE_PROJECT_DIR}/.claude/hooks/guard_data.py\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
