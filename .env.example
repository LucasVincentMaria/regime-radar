# ─────────────────────────────────────────────────────────────
# Regime Radar — environment template
# ─────────────────────────────────────────────────────────────
# Copy this file to ".env" and fill in values as needed.
# The real ".env" is gitignored and must NEVER be committed.
#
# v1 needs NO keys at all (yfinance is keyless). These slots exist
# so keyed data sources can be dropped in later without code changes.
# ─────────────────────────────────────────────────────────────

# --- Optional: FRED (free key) for real CPI/GDP/PCE macro data later ---
# Get a free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# --- Optional: Alpaca (free tier) for a real tick stream later ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# --- App settings (safe defaults; override if you like) ---
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO
